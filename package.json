{
  "name": "@zetagoaurum-dev/plester",
  "version": "1.0.1",
  "description": "Global Self-Healing & Autocorrect Runtime Engine — transparent typo correction, malformed JSON repair, and silent global exception isolation with zero dependencies.",
  "keywords": [
    "self-healing",
    "runtime",
    "proxy",
    "typo-correction",
    "autocorrect",
    "zero-dependency",
    "json-healer",
    "exception-guard"
  ],
  "license": "MIT",
  "type": "module",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "types": "./index.d.ts"
    },
    "./proxy": {
      "import": "./dist/esm/proxy.js",
      "require": "./dist/cjs/proxy.js",
      "types": "./index.d.ts"
    },
    "./json": {
      "import": "./dist/esm/json.js",
      "require": "./dist/cjs/json.js",
      "types": "./index.d.ts"
    },
    "./core": {
      "import": "./dist/esm/core.js",
      "require": "./dist/cjs/core.js",
      "types": "./index.d.ts"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "index.d.ts",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "npm run build:esm && npm run build:cjs",
    "build:esm": "tsc -p tsconfig.esm.json",
    "build:cjs": "tsc -p tsconfig.cjs.json",
    "prepublishOnly": "npm run build",
    "publish:now": "node scripts/publish.mjs",
    "test": "node scripts/test.mjs"
  },
  "devDependencies": {
    "typescript": "^5.4.0"
  }
}
