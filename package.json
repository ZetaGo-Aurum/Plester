{
  "name": "@zetagoaurum-dev/plester",
  "version": "1.1.0",
  "description": "Global Self-Healing & Autocorrect Runtime Engine — transparent typo correction (Damerau–Levenshtein + Jaro-Winkler), malformed JSON repair, and silent global exception isolation with zero dependencies.",
  "keywords": [
    "self-healing",
    "runtime",
    "proxy",
    "typo-correction",
    "autocorrect",
    "zero-dependency",
    "json-healer",
    "exception-guard",
    "damerau-levenshtein",
    "jaro-winkler",
    "fuzzy-matching",
    "runtime-engine",
    "v8",
    "nodejs",
    "bun",
    "load-bearing",
    "auto-heal",
    "crash-prevention",
    "developer-tools",
    "debugging"
  ],
  "license": "MIT",
  "author": "ZetaGo-Aurum (https://github.com/ZetaGo-Aurum)",
  "homepage": "https://github.com/ZetaGo-Aurum/Plester#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ZetaGo-Aurum/Plester.git"
  },
  "bugs": {
    "url": "https://github.com/ZetaGo-Aurum/Plester/issues"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/ZetaGo-Aurum"
  },
  "engines": {
    "node": ">=18.0.0",
    "bun": ">=1.0.0"
  },
  "type": "module",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "types": "./index.d.ts"
    },
    "./proxy": {
      "import": "./dist/esm/proxy.js",
      "require": "./dist/cjs/proxy.js",
      "types": "./index.d.ts"
    },
    "./json": {
      "import": "./dist/esm/json.js",
      "require": "./dist/cjs/json.js",
      "types": "./index.d.ts"
    },
    "./core": {
      "import": "./dist/esm/core.js",
      "require": "./dist/cjs/core.js",
      "types": "./index.d.ts"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "index.d.ts",
    "README.md",
    "LICENSE",
    "robots.txt"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "npm run build:esm && npm run build:cjs",
    "build:esm": "tsc -p tsconfig.esm.json",
    "build:cjs": "tsc -p tsconfig.cjs.json",
    "prepublishOnly": "npm run build",
    "publish:now": "node scripts/publish.mjs",
    "test": "node scripts/test.mjs"
  },
  "devDependencies": {
    "typescript": "^5.4.0"
  }
}
